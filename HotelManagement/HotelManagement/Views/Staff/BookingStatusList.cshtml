@using HotelManagement.Models.Entities
@model HotelManagement.Models.Common.PagedResult<HotelManagement.Models.ViewModels.BookingViewModel>

@{
    ViewData["Title"] = "Danh sách đặt phòng";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<div class="container-fluid py-4">

    <h2 class="mb-4">Danh sách đặt phòng</h2>

    <div class="card shadow border-0">
        <div class="card-body">

            <!-- SEARCH -->
            <form method="get" class="d-flex gap-2 mb-4">

                <select name="search" class="form-control" style="width:250px">
                    <option value="">--- Chọn trạng thái ---</option>

                    @foreach (BookingStatus status in Enum.GetValues(typeof(BookingStatus)))
                    {
                        <option value="@status">@status</option>
                    }

                </select>

                <button class="btn btn-primary">
                    <i class="fas fa-search"></i> Tìm kiếm
                </button>

            </form>

            <!-- TABLE -->
            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Id</th>
                            <th>Tên khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thông tin chi tiết</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 text-muted">#@item.BookingId</td>
                                <td>@item.CustomerName</td>
                                <td>@item.CreatedDate</td>
                                <td>
                                    <span class="badge
                                        @(item.Status == "Pending" ? "bg-warning" :
                                          item.Status == "Confirmed" ? "bg-success" :
                                          "bg-danger")">
                                        @item.Status
                                    </span>
                                </td>

                                <td class="text-center">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.BookingId"
                                       class="btn btn-sm btn-primary text-white">
                                        Cập nhật trạng thái
                                    </a>
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <!-- PAGINATION -->
            <div class="d-flex justify-content-center mt-4">
                <ul class="pagination">

                    @if (Model.Page > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="BookingStatusList"
                               asp-route-page="@(Model.Page - 1)"
                               asp-route-search="@ViewBag.Search">
                                Previous
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="BookingStatusList"
                               asp-route-page="@i"
                               asp-route-search="@ViewBag.Search">
                                @i
                            </a>
                        </li>
                    }

                    @if (Model.Page < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="BookingStatusList"
                               asp-route-page="@(Model.Page + 1)"
                               asp-route-search="@ViewBag.Search">
                                Next
                            </a>
                        </li>
                    }

                </ul>
            </div>

        </div>
    </div>

</div>