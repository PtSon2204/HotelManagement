
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Staff Management</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <style>

        body {
            background: #f5f6fa;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            background: white;
            border-right: 1px solid #eee;
            position: fixed;
        }

            .sidebar .menu-title {
                font-size: 13px;
                color: gray;
                padding: 15px;
            }

            .sidebar a {
                display: block;
                padding: 12px 20px;
                color: #333;
                text-decoration: none;
            }

                .sidebar a:hover {
                    background: #f2f2f2;
                }

            .sidebar .active {
                background: #0d6efd;
                color: white;
            }

        .content {
            margin-left: 250px;
        }

        .topbar {
            background: white;
            border-bottom: 1px solid #eee;
            padding: 10px 20px;
        }

        .card-dashboard {
            border: none;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .activity-item {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .avatar-circle {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

    </style>

</head>

<body>

    <div class="sidebar">

        <h4 class="p-3">SMS</h4>

        <div class="menu-title">MENU CHÍNH</div>

        <a asp-action="Index" asp-controller="Staff"><i class="bi bi-grid"></i> Dashboard</a>
        <a asp-action="CustomerList" asp-controller="Staff"><i class="bi bi-people"></i> Người dùng</a>
        <a asp-action="BookingStatusList" asp-controller="Staff"><i class="bi bi-mortarboard"></i> Danh sách đặt phòng</a>
        <a asp-action="RoomStatus" asp-controller="Staff"><i class=""></i> Trạng thái phòng </a>
        <a asp-action="ServicePackage" asp-controller="Staff"><i class=""></i> Danh sách dịch vụ </a>
        <a><i class="bi bi-box-arrow-right"></i> Đăng Xuất</a>

    </div>


    <div class="content">

        <div class="topbar d-flex justify-content-between">
            <div>
                🔔
                <span class="ms-3">Staff</span>
            </div>
        </div>

        <div class="container-fluid mt-4">
            @RenderBody()
        </div>

    </div>

</body>
</html>