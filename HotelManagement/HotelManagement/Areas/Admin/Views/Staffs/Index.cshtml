@model IEnumerable<HotelManagement.Models.ViewModels.StaffViewModel>

@{
    ViewData["Title"] = "Quản lý nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container" style="padding-top: 50px;">
    <h2>Quản lý nhân viên</h2>

    <p>
        <a asp-area="Admin" asp-controller="Staffs" asp-action="Create" class="btn btn-primary">Thêm nhân viên mới</a>
    </p>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Họ tên</th>
                <th>Giới tính</th>
                <th>Ngày sinh</th>
                <th>Email</th>
                <th>Số điện thoại</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.Gender</td>
                    <td>@item.DateOfBirth?.ToString("dd/MM/yyyy")</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>
                        <a asp-area="Admin" asp-controller="Staffs" asp-action="Edit" asp-route-id="@item.StaffId" class="btn btn-sm btn-warning">Sửa</a>
                        <button type="button" class="btn btn-sm btn-danger"
                                data-toggle="modal"
                                data-target="#deleteModal"
                                data-id="@item.StaffId"
                                data-name="@item.FullName">
                            Xóa
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Xác nhận xóa</h5>
                <button type="button" class="btn-close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                Bạn có chắc chắn muốn xóa nhân viên <strong id="deleteStaffName"></strong> không?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/staffs-index.js"></script>
}
