@model HotelManagement.Models.ViewModels.ServiceViewModel

@{
    ViewData["Title"] = "Sửa dịch vụ";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container" style="padding-top: 50px;">
    <h2>Sửa dịch vụ</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-area="Admin" asp-controller="Services" asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ServiceId" />

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label">Tên dịch vụ</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Price" class="control-label">Giá (VND)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="IsActive" class="control-label d-block">Trạng thái</label>
                    <select asp-for="IsActive" class="form-control">
                        <option value="true">Hoạt động</option>
                        <option value="false">Không hoạt động</option>
                    </select>
                </div>

                <div class="form-group mb-3 mt-4">
                    <input type="submit" value="Lưu" class="btn btn-primary" />
                    <a asp-area="Admin" asp-controller="Services" asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
